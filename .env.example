# 作者账号 uid，用于登录页卡墙 / 新用户示例卡 / /author 公开预览。
# VITE_ 前缀 = 构建期变量，改了要重新构建/部署。
VITE_AUTHOR_UID="your-firebase-uid"

# 注：KIMI_API_KEY 是服务端变量（无 VITE_ 前缀，只配在 Vercel 环境变量里，不放这里）。
# 注：本地连模拟器用 .env.emulator + `npm run dev:emu`，不需要在 .env 里配。

# Serverless API 在本地 / vercel dev 下默认禁止直读生产 Firestore。
# 只有你明确知道自己在做什么时，才临时打开这个开关。
ALLOW_DEV_PROD_FIRESTORE="false"

# Serverless API 在本地 / vercel dev 下默认禁止访问生产侧服务（如 Kimi / Blob）。
ALLOW_DEV_PROD_SERVICES="false"
