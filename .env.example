# Public author identifier used by the login wall and /author preview.
VITE_AUTHOR_UID="your-public-id"

# Environment boundary. Local development must use a local Supabase instance by default.
VITE_VERCEL_ENV="development"
VITE_SUPABASE_ENV="development"
VITE_SUPABASE_URL="http://127.0.0.1:54321"
VITE_SUPABASE_PUBLISHABLE_KEY="your-local-publishable-key"
# Keep false/empty. Only use for a separately verified hosted development project.
VITE_ALLOW_HOSTED_SUPABASE_DEV="false"
# Keep false/empty. Prevents `vite preview` from using a production bundle against prod locally.
VITE_ALLOW_LOCAL_PRODUCTION_PREVIEW="false"

# Server-side Supabase config. These are intentionally separate from VITE_*.
SUPABASE_ENV="development"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_your_key"
# Required only when Preview uses a hosted development Supabase project.
ALLOW_HOSTED_SUPABASE_DEV="false"

# Default: Kimi Code OpenAI-compatible endpoint.
# KIMI_API_KEY="borrowed-key-goes-in-Vercel-only"
# KIMI_API_ENDPOINT="https://api.kimi.com/coding/v1/chat/completions"
# KIMI_MODEL="kimi-for-coding"

# If the existing key is a Kimi Platform key, use the endpoint/model that key already supports:
# KIMI_API_ENDPOINT="https://api.moonshot.cn/v1/chat/completions"
# KIMI_MODEL="kimi-k2.6"

# Reserved for the future image-analysis caller; the current UI does not invoke it.
# KIMI_IMAGE_MAX_TOKENS="4096"

# Local serverless safety switch. Keep false/empty.
ALLOW_DEV_PROD_SERVICES="false"
VITE_ONBOARDING_VISION_ENABLED="false"
