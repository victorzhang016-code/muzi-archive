rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    function sharingEnabled(userId) {
      return exists(/databases/$(database)/documents/wardrobe_users/$(userId)) &&
             get(/databases/$(database)/documents/wardrobe_users/$(userId)).data.shareEnabled == true;
    }
    // 字段大小上限（防写入滥用 / 超大文档）。base64 图本就受 Firestore 单文档 1MiB 硬上限约束，
    // 这里再叠一道；正常压缩后的图片（720px/78% JPEG）远小于上限，不会被误拒。
    function withinSizeLimits() {
      let d = request.resource.data;
      return (!('name' in d) || (d.name is string && d.name.size() <= 200))
        && (!('brand' in d) || (d.brand is string && d.brand.size() <= 200))
        && (!('story' in d) || (d.story is string && d.story.size() <= 10000))
        && (!('imageUrl' in d) || (d.imageUrl is string && d.imageUrl.size() <= 1200000))
        && (!('photoBase64' in d) || (d.photoBase64 is string && d.photoBase64.size() <= 1200000));
    }

    // 每个用户的分享设置 — 任何人可读，本人可写
    match /wardrobe_users/{userId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /wardrobe_items/{itemId} {
      // 本人读，或主人开启了分享
      allow read: if isDocOwner() || sharingEnabled(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && withinSizeLimits();
      allow update: if isDocOwner() && uidNotModified() && areImmutableFieldsUnchanged(['createdAt', 'userId']) && withinSizeLimits();
      allow delete: if isDocOwner();
    }

    // Best Match — 用户记录的"心中最佳搭配"
    match /best_matches/{matchId} {
      // 本人读，或主人开启了分享（与 wardrobe_items 一致）
      allow read: if isDocOwner() || sharingEnabled(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && withinSizeLimits();
      allow update: if isDocOwner() && uidNotModified() && areImmutableFieldsUnchanged(['createdAt', 'userId']) && withinSizeLimits();
      allow delete: if isDocOwner();
    }

    // 审美档案缓存 — 文档 ID 即 userId
    match /aesthetic_profiles/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
